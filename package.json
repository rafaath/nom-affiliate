{
  "name": "nom-affiliate-partner-program",
  "version": "0.1.0",
  "private": true,
  "description": "Nom Partner Program portal for affiliate, sales, and implementation partners.",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "next dev -p 3021 --turbopack",
    "build": "next build --turbopack",
    "start": "next start -p 3021",
    "lint": "eslint .",
    "type-check": "next typegen && tsc --noEmit",
    "test": "vitest run tests/unit tests/components --pool=forks --no-isolate --no-file-parallelism --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate": "npm run lint && npm run type-check && npm run test && npm run build"
  },
