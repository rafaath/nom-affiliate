    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
